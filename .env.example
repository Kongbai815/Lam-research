# ScholarLens AI supports three AI key modes:
# 1) server-owned default key, 2) encrypted account-saved user key, 3) temporary BYOK key in Settings.

PORT=3000
NODE_ENV=production

# Required ranking backend. The frontend calls this app's Express API,
# and Express will proxy to the external FastAPI ranking service.
RANKING_API_URL=https://researcher-ranking-szk6rqcdwa-uc.a.run.app

# Optional. Only set this if the ranking service requires bearer auth.
RANKING_API_AUTH_TOKEN=

# Required for encrypting account-saved AI API keys at rest.
# Set this to a long random secret in production.
RESEARCH_AI_SECRET=

# Optional server-owned AI fallback. If set, new users can use AI without pasting a personal key.
DEFAULT_AI_PROVIDER=gpt
DEFAULT_AI_API_BASE_URL=https://api.openai.com/v1
DEFAULT_AI_MODEL=gpt-5.2
DEFAULT_AI_API_KEY=
OPENAI_API_KEY=

# Optional. When set, Google sign-in will open the OAuth consent page.
# The backend OAuth callback is implemented; configure the same redirect URL in Google Cloud.
VITE_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Optional future production storage target. Current implementation uses encrypted local JSON on the server.
GOOGLE_USER_DATA_BUCKET=

# Development only. If true in production, /api/auth/request-code returns the code in JSON.
RESEARCH_AI_SHOW_DEV_CODE=false
