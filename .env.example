# ResearchAI uses BYOK (Bring Your Own Key).
# End users enter their own OpenAI/Gemini/custom API key in Settings.
# Do not put your private AI provider key here unless you intentionally want a server-owned fallback.

PORT=3000
NODE_ENV=production

# Optional but recommended. Server-side key for OpenAlex REST API requests.
# Get a free key from OpenAlex, then keep it server-side instead of storing it in browser settings.
OPENALEX_API_KEY=

# Optional ranking backend. The frontend should call this app's Express API,
# and Express will proxy to the external FastAPI ranking service.
RANKING_API_URL=https://researcher-ranking-szk6rqcdwa-uc.a.run.app

# Optional. Only set this if the ranking service requires bearer auth.
RANKING_API_AUTH_TOKEN=

# Optional. When set, Google sign-in will open the OAuth consent page.
# A backend OAuth callback still needs to be implemented before production use.
VITE_GOOGLE_CLIENT_ID=

# Development only. If true in production, /api/auth/request-code returns the code in JSON.
RESEARCH_AI_SHOW_DEV_CODE=false
